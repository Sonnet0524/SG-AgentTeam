{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "pm": {
      "description": "PM - 项目管理和协调",
      "mode": "primary",
      "prompt": "{file:./practice/agents/pm/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "review-process",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git *": "allow"
        }
      }
    },
    "core": {
      "description": "Core - 核心数据处理和工具开发",
      "mode": "primary",
      "prompt": "{file:./practice/agents/core/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "ai": {
      "description": "AI - 向量嵌入和语义搜索",
      "mode": "primary",
      "prompt": "{file:./practice/agents/ai/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "integration": {
      "description": "Integration - opencode集成和连接器开发",
      "mode": "primary",
      "prompt": "{file:./practice/agents/integration/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "test": {
      "description": "Test - 测试框架和质量保证",
      "mode": "primary",
      "prompt": "{file:./practice/agents/test/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "deny",
        "bash": {
          "pytest *": "allow",
          "git diff": "allow",
          "git log*": "allow"
        }
      }
    },
    "research": {
      "description": "Research - 框架层面的研究专家，辅助用户形成Agent Team框架设计思路",
      "mode": "primary",
      "prompt": "{file:./agents/research/CATCH_UP.md}",
      "skills": [
        "git-workflow",
        "quality-gate"
      ],
      "memory_index": "framework/memory-index.yaml",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git add": "allow",
          "git commit": "allow"
        }
      }
    }
  }
}
