{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "pm": {
      "description": "PM - 项目管理和协调",
      "mode": "primary",
      "prompt": "{file:./practice/agents/pm/CATCH_UP.md}",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git *": "allow"
        }
      }
    },
    "data": {
      "description": "Data - 数据类型、解析器和工具",
      "mode": "primary",
      "prompt": "{file:./practice/agents/data/CATCH_UP.md}",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "template": {
      "description": "Template - 模板引擎和配置系统",
      "mode": "primary",
      "prompt": "{file:./practice/agents/template/CATCH_UP.md}",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "pytest *": "allow",
          "black *": "allow",
          "flake8 *": "allow",
          "mypy *": "allow"
        }
      }
    },
    "test": {
      "description": "Test - 测试框架和质量保证",
      "mode": "primary",
      "prompt": "{file:./practice/agents/test/CATCH_UP.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "pytest *": "allow",
          "git diff": "allow",
          "git log*": "allow"
        }
      }
    },
    "research": {
      "description": "Research - 框架层面的研究专家，辅助用户形成Agent Team框架设计思路",
      "mode": "primary",
      "prompt": "{file:./practice/agents/research/CATCH_UP.md}",
      "permission": {
        "edit": "ask",
        "bash": {
          "git push": "ask",
          "git add": "allow",
          "git commit": "allow"
        }
      }
    }
  }
}
